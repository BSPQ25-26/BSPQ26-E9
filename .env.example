# Copy this file to .env and fill in real values.
# Do not commit real credentials.

# Local Docker defaults use SQLite databases under ./data when the
# per-service DB URLs below are unset or empty.

# Supabase project URL and keys (optional for DB-only migration, but useful for frontend/SDK work)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional per-service DB URLs for Supabase/Postgres.
# Leave empty for local SQLite.
AUTH_DATABASE_URL=
INVENTORY_DATABASE_URL=
TRANSACTION_DATABASE_URL=

# Wallabot agentic service
OPENAI_API_KEY=
TAVILY_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=wallabot

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8001/auth/google/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:5173/#/auth/callback

# Facebook OAuth2
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8001/auth/facebook/callback

# Optional Postgres schema. Leave empty for local SQLite.
DB_SCHEMA=
