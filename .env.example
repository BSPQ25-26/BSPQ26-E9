# Copy this file to .env and fill in real values.
# Do not commit real credentials.

# Supabase project URL and keys (optional for DB-only migration, but useful for frontend/SDK work)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Per-service DB URLs (single shared schema via role search_path)
AUTH_DATABASE_URL=postgresql://auth_service:AUTH_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
INVENTORY_DATABASE_URL=postgresql://inventory_service:INVENTORY_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
TRANSACTION_DATABASE_URL=postgresql://transaction_service:TRANSACTION_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Keep this off until Sprint 3 (agentic service)
LANGCHAIN_TRACING_V2=false

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8001/auth/google/callback

# Facebook OAuth2
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8001/auth/facebook/callback

# Database schema
DB_SCHEMA=wallabot